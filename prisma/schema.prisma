generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Clinic {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  plan      String   @default("free")
  logoUrl   String?  @map("logo_url")
  phone     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  patients            Patient[]
  appointments        Appointment[]
  treatments          Treatment[]
  payments            Payment[]
  automations         Automation[]
  automationLogs      AutomationLog[]
  aiInsights          AiInsight[]
  patientInteractions PatientInteraction[]

  @@map("clinics")
}

model User {
  id        String   @id @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  name      String
  email     String
  role      String   @default("doctor")
  avatarUrl String?  @map("avatar_url")
  crm       String?
  specialty String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clinic              Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  patientInteractions PatientInteraction[]

  @@map("users")
}

model Patient {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId    String    @map("clinic_id") @db.Uuid
  name        String
  phone       String?
  email       String?
  birthDate   DateTime? @map("birth_date") @db.Date
  gender      String?
  cpf         String?
  origin      String?
  notes       String?
  tags        String[]  @default([])
  lastVisitAt DateTime? @map("last_visit_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  clinic              Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  treatments          Treatment[]
  payments            Payment[]
  patientInteractions PatientInteraction[]
  automationLogs      AutomationLog[]

  @@map("patients")
}

model Appointment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  patientId    String   @map("patient_id") @db.Uuid
  doctorId     String?  @map("doctor_id") @db.Uuid
  scheduledAt  DateTime @map("scheduled_at")
  durationMin  Int      @default(30) @map("duration_min")
  type         String?
  status       String   @default("scheduled")
  notes        String?
  reminderSent Boolean  @default(false) @map("reminder_sent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor   User?     @relation(fields: [doctorId], references: [id])
  payments Payment[]

  @@map("appointments")
}

model Treatment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String    @map("clinic_id") @db.Uuid
  patientId    String    @map("patient_id") @db.Uuid
  name         String
  description  String?
  value        Decimal?  @db.Decimal(12, 2)
  stage        String    @default("lead")
  stageOrder   Int       @default(0) @map("stage_order")
  probability  Int       @default(50)
  expectedDate DateTime? @map("expected_date") @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("treatments")
}

model Payment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId      String    @map("clinic_id") @db.Uuid
  patientId     String    @map("patient_id") @db.Uuid
  treatmentId   String?   @map("treatment_id") @db.Uuid
  appointmentId String?   @map("appointment_id") @db.Uuid
  description   String?
  amount        Decimal   @db.Decimal(12, 2)
  method        String?
  status        String    @default("pending")
  dueDate       DateTime? @map("due_date") @db.Date
  paidAt        DateTime? @map("paid_at")
  receiptUrl    String?   @map("receipt_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment   Treatment?   @relation(fields: [treatmentId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("payments")
}

model Automation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  name         String
  triggerEvent String   @map("trigger_event")
  actionType   String   @map("action_type")
  config       Json     @default("{}")
  delayMinutes Int      @default(0) @map("delay_minutes")
  isActive     Boolean  @default(true) @map("is_active")
  executions   Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  clinic Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  logs   AutomationLog[]

  @@map("automations")
}

model AutomationLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  automationId String   @map("automation_id") @db.Uuid
  patientId    String?  @map("patient_id") @db.Uuid
  triggerEvent String   @map("trigger_event")
  actionType   String   @map("action_type")
  status       String
  response     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  clinic     Clinic     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  automation Automation @relation(fields: [automationId], references: [id])
  patient    Patient?   @relation(fields: [patientId], references: [id])

  @@map("automation_logs")
}

model AiInsight {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId    String   @map("clinic_id") @db.Uuid
  type        String
  title       String
  body        String
  impact      String?
  data        Json?
  isRead      Boolean  @default(false) @map("is_read")
  generatedAt DateTime @default(now()) @map("generated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

model PatientInteraction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  patientId String   @map("patient_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  type      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("patient_interactions")
}
